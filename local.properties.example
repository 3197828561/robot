# 复制到项目根目录 local.properties（该文件已在 .gitignore 中，不会提交）
# Android SDK 路径由 Android Studio 自动维护，请勿删除 sdk.dir

# HTTP API（当前阿里云 ECS）
api.base.url=http://47.103.157.213/api

# MQTT Broker（与 cloud_comm、EMQX 一致）
mqtt.host=47.103.157.213
mqtt.port=1883
mqtt.username=app_user_001
# 不要提交真实密码；从私下保存的联调信息中复制到本机 local.properties
mqtt.password=填入App_MQTT密码

# 联调默认设备 ID（设备列表未选时 fallback，正式流程从 HTTP 设备列表选择）
mqtt.default_device_id=rk3588
