# 复制为 .env 后修改：cp .env.example .env

# ECS 公网 IP 或域名（不含协议）
PUBLIC_HOST=47.103.157.213

# PostgreSQL
POSTGRES_USER=vgsolar
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=vgsolar

# JWT 签名密钥（至少 32 位随机字符串）
JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# EMQX MQTT 应用账号（当前服务器已创建；HTTP-only Compose 不读取这两项）
EMQX_APP_USERNAME=app_user_001
EMQX_APP_PASSWORD=不要提交真实MQTT密码

# API 首次启动自动创建的测试账号
API_BOOTSTRAP_EMAIL=test@vgsolar.com
API_BOOTSTRAP_PASSWORD=Test123456!

# Robot map upload and public download (generate a real token on the server)
MAP_PUBLIC_BASE_URL=http://47.103.157.213
MAP_UPLOAD_TOKEN=change_me_robot_map_upload_token
